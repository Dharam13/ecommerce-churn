# ═══════════════════════════════════════════════════════════
#  .env  —  Environment Variables for Docker Compose
# ═══════════════════════════════════════════════════════════

# ── PostgreSQL ────────────────────────────────────────────
POSTGRES_DB=ecommerce_churn
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ── App database URL (auto-set in docker-compose, override for local dev) ─
DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/ecommerce_churn

# ── Schema names ──────────────────────────────────────────
BRONZE_SCHEMA=bronze
SILVER_SCHEMA=silver
GOLD_SCHEMA=gold

# ── Bootstrap: run full ETL on first start ────────────────
RUN_BOOTSTRAP=true

# ── Optional auto simulation (runs in app container) ─────
ENABLE_AUTO_SIMULATION=false
AUTO_SIMULATION_INTERVAL_SEC=30
AUTO_SIMULATION_MODE=new

# ── Airflow ──────────────────────────────────────────────
AIRFLOW_USERNAME=admin
AIRFLOW_PASSWORD=admin

# ── GenAI (optional — for AI Insights tab) ───────────────
GOOGLE_API_KEY=
